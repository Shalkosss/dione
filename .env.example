# ============================================================
# DIONE WEB — Variables de entorno
# Copiar este archivo a .env.local para desarrollo local.
# En Vercel: Settings -> Environment Variables.
# ============================================================

# --- FASE 1 ---
# No requiere variables. La app funciona 100% client-side.

# --- FASE 2 (Watchlist + precios automaticos) ---
# API key gratuita de Finnhub: https://finnhub.io/register
VITE_FINNHUB_KEY=

# --- FASE 3 (Thesis Log + Performance, base de datos) ---
# Proyecto Supabase: https://supabase.com  -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
